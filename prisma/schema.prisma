// Missing Frame - Full Database Schema
// Полная схема БД на основе ТЗ v2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PM
  PRODUCER
  CREATIVE_DIRECTOR
  EMPLOYEE
  FREELANCER
  OBSERVER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  passwordHash      String
  role              UserRole
  status            UserStatus  @default(ACTIVE)
  
  // 2FA
  twoFactorEnabled  Boolean     @default(false)
  twoFactorSecret   String?
  telegramChatId    String?     @unique
  
  // Profile
  firstName         String?
  lastName          String?
  phone             String?
  avatar            String?
  
  // Password management
  mustChangePassword Boolean    @default(true)
  lastPasswordChange DateTime?
  
  // Sessions
  sessions          Session[]
  
  // Relations
  employeeCard      EmployeeCard?
  assignedProjects  ProjectAssignment[]
  createdProjects   Project[]          @relation("ProjectCreator")
  ownedProjects     Project[]          @relation("ProjectOwner")
  tasks             Task[]
  meetings          Meeting[]          @relation("MeetingParticipants")
  organizedMeetings Meeting[]          @relation("MeetingOrganizer")
  reviews           Review[]           @relation("ReviewSubject")
  givenReviews      Review[]           @relation("ReviewAuthor")
  notifications     Notification[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@map("sessions")
}

// ============================================
// EMPLOYEE MANAGEMENT
// ============================================

enum Grade {
  INTERN
  JUNIOR
  MIDDLE
  SENIOR
  LEAD
  PRINCIPAL
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  FREELANCE
  CONTRACTOR
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  
  employees   EmployeeCard[]
  projects    ProjectDepartment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("departments")
}

model EmployeeCard {
  id              String          @id @default(uuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  departmentId    String
  department      Department      @relation(fields: [departmentId], references: [id])
  
  position        String
  grade           Grade
  employmentType  EmploymentType
  
  // Contract info
  hireDate        DateTime
  contractEndDate DateTime?
  salary          Decimal?
  
  // Work capacity (hours per week)
  weeklyCapacity  Int             @default(40)
  
  // Skills & Competencies
  competencies    Competency[]
  
  // KPI
  kpiRecords      KPIRecord[]
  
  // HR
  reviews         Review[]        @relation("EmployeeReviews")
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([departmentId])
  @@map("employee_cards")
}

model Competency {
  id              String        @id @default(uuid())
  
  employeeCardId  String
  employeeCard    EmployeeCard  @relation(fields: [employeeCardId], references: [id], onDelete: Cascade)
  
  skill           String        // e.g., "React", "Video Editing", "Project Management"
  level           Int           @default(1) // 1-5 scale
  
  verifiedBy      String?       // User ID who verified
  verifiedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([employeeCardId])
  @@map("competencies")
}

// ============================================
// PROJECTS
// ============================================

enum ProjectStatus {
  DISCUSSION    // На обсуждении
  IN_PROGRESS   // В работе
  OVERDUE       // Просрочен
  FROZEN        // Заморожен
  COMPLETED     // Закончен
  ARCHIVED      // Архив
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Project {
  id              String            @id @default(uuid())
  
  // Basic info
  name            String
  description     String?
  client          String?
  
  status          ProjectStatus     @default(DISCUSSION)
  priority        ProjectPriority   @default(MEDIUM)
  
  // Ownership
  createdById     String
  createdBy       User              @relation("ProjectCreator", fields: [createdById], references: [id])
  
  ownerId         String?           // PM или ответственный
  owner           User?             @relation("ProjectOwner", fields: [ownerId], references: [id])
  
  // Dates
  startDate       DateTime?
  endDate         DateTime?
  actualEndDate   DateTime?
  
  // Budget
  budgetPlanned   Decimal?
  budgetActual    Decimal?
  
  // Risk scoring (Fibonacci)
  riskScore       Int?              // Calculated risk score
  riskClass       String?           // "низкий", "брать с условиями", "не брать"
  
  // Relations
  departments     ProjectDepartment[]
  assignments     ProjectAssignment[]
  tasks           Task[]
  meetings        Meeting[]
  decisions       Decision[]
  risks           Risk[]
  finances        Finance[]
  milestones      Milestone[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([status])
  @@index([ownerId])
  @@map("projects")
}

// Many-to-many: Project <-> Department
model ProjectDepartment {
  id            String     @id @default(uuid())
  
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  
  createdAt     DateTime   @default(now())
  
  @@unique([projectId, departmentId])
  @@index([projectId])
  @@index([departmentId])
  @@map("project_departments")
}

enum AssignmentRole {
  PM
  PRODUCER
  CREATIVE_LEAD
  TEAM_MEMBER
  CONSULTANT
}

model ProjectAssignment {
  id                String         @id @default(uuid())
  
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role              AssignmentRole
  allocatedHours    Int?           // Часов выделено на проект
  
  startDate         DateTime?
  endDate           DateTime?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
  @@map("project_assignments")
}

// ============================================
// TASKS
// ============================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id              String        @id @default(uuid())
  
  title           String
  description     String?
  
  status          TaskStatus    @default(TODO)
  priority        TaskPriority  @default(MEDIUM)
  
  // Assignment
  assignedToId    String?
  assignedTo      User?         @relation(fields: [assignedToId], references: [id])
  
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Dates
  dueDate         DateTime?
  startDate       DateTime?
  completedAt     DateTime?
  
  // Tracking
  estimatedHours  Int?
  actualHours     Int?
  
  // Subtasks
  parentTaskId    String?
  parentTask      Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks        Task[]        @relation("TaskSubtasks")
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([assignedToId])
  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

// ============================================
// CALENDAR & MEETINGS
// ============================================

enum EventType {
  MEETING
  DEADLINE
  SHOOT
  MILESTONE
  PERSONAL
}

model CalendarEvent {
  id              String      @id @default(uuid())
  
  title           String
  description     String?
  
  type            EventType   @default(MEETING)
  
  startTime       DateTime
  endTime         DateTime
  
  location        String?
  
  // Google/Apple sync
  externalId      String?     @unique // ID из Google Calendar
  syncedWith      String?     // "google", "apple"
  
  // Relations
  projectId       String?
  meetingId       String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([startTime])
  @@map("calendar_events")
}

model Meeting {
  id              String      @id @default(uuid())
  
  title           String
  agenda          String?
  
  startTime       DateTime
  endTime         DateTime
  
  location        String?
  meetingUrl      String?     // Zoom/Meet link
  
  // Relations
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id])
  
  organizerId     String
  organizer       User        @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  
  participants    User[]      @relation("MeetingParticipants")
  
  // Notes
  notes           String?
  decisions       Decision[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([projectId])
  @@index([startTime])
  @@map("meetings")
}

// ============================================
// DECISIONS & RISKS
// ============================================

model Decision {
  id              String      @id @default(uuid())
  
  title           String
  description     String
  
  decidedBy       String      // User ID или роль
  decidedAt       DateTime    @default(now())
  
  impact          String?     // Оценка влияния
  
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  meetingId       String?
  meeting         Meeting?    @relation(fields: [meetingId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([projectId])
  @@map("decisions")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  IDENTIFIED
  MONITORING
  MITIGATED
  CLOSED
}

model Risk {
  id              String      @id @default(uuid())
  
  title           String
  description     String
  
  level           RiskLevel
  status          RiskStatus  @default(IDENTIFIED)
  
  probability     Int         @default(50) // 0-100%
  impact          Int         @default(50) // 0-100%
  
  mitigation      String?     // План снижения риска
  
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  identifiedBy    String?     // User ID
  identifiedAt    DateTime    @default(now())
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([projectId])
  @@index([status])
  @@map("risks")
}

// ============================================
// FINANCE & KPI
// ============================================

model Finance {
  id              String      @id @default(uuid())
  
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  category        String      // "доход", "расход", "маржа"
  amount          Decimal
  
  description     String?
  date            DateTime
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([projectId])
  @@map("finances")
}

model KPIRecord {
  id              String        @id @default(uuid())
  
  employeeCardId  String
  employeeCard    EmployeeCard  @relation(fields: [employeeCardId], references: [id], onDelete: Cascade)
  
  metric          String        // "выручка", "проектов завершено", "качество работы"
  value           Decimal
  target          Decimal?
  
  period          String        // "2024-Q1", "2024-01"
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([employeeCardId])
  @@index([period])
  @@map("kpi_records")
}

model Milestone {
  id              String      @id @default(uuid())
  
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  dueDate         DateTime
  completedAt     DateTime?
  
  status          String      @default("pending") // "pending", "completed", "overdue"
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([projectId])
  @@map("milestones")
}

// ============================================
// HR & REVIEWS
// ============================================

model Review {
  id              String        @id @default(uuid())
  
  employeeCardId  String
  employeeCard    EmployeeCard  @relation("EmployeeReviews", fields: [employeeCardId], references: [id], onDelete: Cascade)
  
  subjectId       String        // User being reviewed
  subject         User          @relation("ReviewSubject", fields: [subjectId], references: [id])
  
  authorId        String        // User giving review
  author          User          @relation("ReviewAuthor", fields: [authorId], references: [id])
  
  reviewDate      DateTime
  
  // Ratings (1-5)
  technicalSkills Int?
  communication   Int?
  teamwork        Int?
  productivity    Int?
  
  comments        String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([employeeCardId])
  @@index([subjectId])
  @@map("reviews")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  TASK_ASSIGNED
  TASK_DEADLINE
  MEETING_REMINDER
  PROJECT_UPDATE
  SYSTEM_ALERT
}

model Notification {
  id              String            @id @default(uuid())
  
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            NotificationType
  title           String
  message         String
  
  isRead          Boolean           @default(false)
  readAt          DateTime?
  
  // Metadata
  link            String?           // Deep link to related entity
  metadata        Json?
  
  createdAt       DateTime          @default(now())
  
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// AUDIT LOGS
// ============================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
}

model AuditLog {
  id              String        @id @default(uuid())
  
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  
  action          AuditAction
  entity          String        // "Project", "Task", "User"
  entityId        String
  
  changes         Json?         // Old/new values
  
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime      @default(now())
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
